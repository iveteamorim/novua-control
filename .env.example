# Live connector flags
NOVUA_CONTROL_ENABLE_GITHUB_LIVE=0
NOVUA_CONTROL_ENABLE_VERCEL_LIVE=0
NOVUA_CONTROL_ENABLE_LINEAR_LIVE=0

# GitHub live ingestion
GITHUB_TOKEN=
NOVUA_CONTROL_GITHUB_REPO=owner/repository

# Vercel live ingestion
VERCEL_TOKEN=
NOVUA_CONTROL_VERCEL_PROJECT_ID=
NOVUA_CONTROL_VERCEL_TEAM_ID=

# Linear live ingestion
LINEAR_API_KEY=
NOVUA_CONTROL_LINEAR_TEAM_KEY=

# Durable incident store (optional, recommended for pilot deployments)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NOVUA_CONTROL_SUPABASE_BUCKET=novua-control
NOVUA_CONTROL_SUPABASE_OBJECT=control-store.json

# App auth/session secret (recommended for production)
NOVUA_CONTROL_AUTH_SECRET=
